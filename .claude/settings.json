{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -Rn --rawfile ctx \"${CLAUDE_PROJECT_DIR:-.}/.claude/tdd-directive.md\" '{hookSpecificOutput:{hookEventName:\"UserPromptSubmit\",additionalContext:$ctx}}' 2>/dev/null || true",
            "statusMessage": "TDDオーケストレーション指示を注入中..."
          }
        ]
      }
    ]
  }
}
